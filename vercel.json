{
  "version": 2,
  "functions": {
    "api/sops/[id].js": {
      "includeFiles": "deliverables/**/README.md"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/operationsplaybook", "destination": "/operationsplaybook/index.html" },
    { "source": "/operationsplaybook/", "destination": "/operationsplaybook/index.html" }
  ]
}
